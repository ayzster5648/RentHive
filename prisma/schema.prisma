// RentHive data model.
// Uses PostgreSQL for both local dev and production (Vercel-ready).
// Set DATABASE_URL in .env to your Postgres connection string (e.g. a free
// Neon or Vercel Postgres database). See INTEGRATIONS.md.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LANDLORD
  TENANT
}

enum UnitStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  ACTIVE
  PENDING
  ENDED
}

enum InvoiceStatus {
  PAID
  DUE
  OVERDUE
  PARTIAL
  VOID
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  RENTED
}

enum ApplicationStage {
  LEAD
  APPLICATION
  SCREENING
}

enum ApplicationStatus {
  NEW
  IN_REVIEW
  APPROVED
  DECLINED
}

enum InspectionType {
  MOVE_IN
  MOVE_OUT
  ROUTINE
}

enum InspectionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum ReminderType {
  LEASE
  RENT
  MAINTENANCE
  INSPECTION
  CUSTOM
}

enum InvoiceType {
  RENT
  DEPOSIT
  LATE_FEE
  UTILITY
  OTHER
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  name               String
  phone              String?
  company            String?
  emergencyContact   String?
  notes              String?
  role               Role     @default(TENANT)
  notifyOverdue      Boolean  @default(true)
  notifyApplications Boolean  @default(true)
  notifyMaintenance  Boolean  @default(true)
  notifyInspections  Boolean  @default(true)
  createdAt          DateTime @default(now())

  // A landlord owns properties; a tenant holds leases.
  properties Property[] @relation("LandlordProperties")
  leases     Lease[]    @relation("TenantLeases")
  requests   MaintenanceRequest[] @relation("TenantRequests")
}

model Property {
  id         String   @id @default(cuid())
  name       String
  address    String
  city       String
  state      String
  zip        String
  type       String   @default("Apartment")
  imageUrl   String?
  landlordId String
  createdAt  DateTime @default(now())

  landlord    User         @relation("LandlordProperties", fields: [landlordId], references: [id], onDelete: Cascade)
  units       Unit[]
  expenses    Expense[]
  inspections Inspection[]
  documents   Document[]
}

model Unit {
  id         String     @id @default(cuid())
  label      String
  beds       Int        @default(1)
  baths      Float      @default(1)
  sqft       Int?
  rent       Float      @default(0)
  status     UnitStatus @default(VACANT)
  propertyId String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases   Lease[]
  requests MaintenanceRequest[]
  listings Listing[]
}

model Lease {
  id            String      @id @default(cuid())
  unitId        String
  tenantId      String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Float
  depositAmount Float       @default(0)
  rentDueDay    Int         @default(1)
  status        LeaseStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())

  unit     Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant   User      @relation("TenantLeases", fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

model Invoice {
  id        String        @id @default(cuid())
  leaseId   String
  type      InvoiceType   @default(RENT)
  amount    Float
  dueDate   DateTime
  status    InvoiceStatus @default(DUE)
  memo      String?
  createdAt DateTime      @default(now())

  lease    Lease     @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float
  method    String   @default("Card")
  paidAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  unitId      String
  tenantId    String
  title       String
  description String
  category    String              @default("General")
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  recurring   Boolean             @default(false)
  assigneeId  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  unit     Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant   User        @relation("TenantRequests", fields: [tenantId], references: [id], onDelete: Cascade)
  assignee ServicePro? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Expense {
  id         String   @id @default(cuid())
  propertyId String?
  category   String   @default("Repairs")
  vendor     String?
  amount     Float
  date       DateTime @default(now())
  status     String   @default("PAID")
  memo       String?
  createdAt  DateTime @default(now())

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model Listing {
  id          String        @id @default(cuid())
  unitId      String
  rent        Float
  status      ListingStatus @default(PUBLISHED)
  headline    String?
  description String?
  createdAt   DateTime      @default(now())

  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id          String            @id @default(cuid())
  listingId   String?
  name        String
  email       String?
  phone       String?
  stage       ApplicationStage  @default(LEAD)
  status      ApplicationStatus @default(NEW)
  creditScore Int?
  income      Float?
  notes       String?
  createdAt   DateTime          @default(now())

  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
}

model ServicePro {
  id        String   @id @default(cuid())
  name      String
  company   String?
  category  String   @default("General")
  phone     String?
  email     String?
  createdAt DateTime @default(now())

  requests MaintenanceRequest[]
}

model Inspection {
  id           String           @id @default(cuid())
  propertyId   String
  unitLabel    String?
  type         InspectionType   @default(ROUTINE)
  status       InspectionStatus @default(SCHEDULED)
  inspector    String?
  scheduledFor DateTime
  notes        String?
  createdAt    DateTime         @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Document {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("pdf")
  sizeKb     Float    @default(0)
  category   String   @default("Lease")
  propertyId String?
  createdAt  DateTime @default(now())

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model Reminder {
  id         String       @id @default(cuid())
  title      String
  type       ReminderType @default(CUSTOM)
  date       DateTime
  propertyId String?
  createdAt  DateTime     @default(now())
}

model Task {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())
}
