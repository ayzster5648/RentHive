# =====================================================================
# RentHive environment. Copy this file to `.env` and fill in values.
#   cp .env.example .env
# Only the first two are required for local dev. Everything else is
# optional — the app simulates those features until you set the keys.
# See INTEGRATIONS.md for step-by-step wiring instructions.
# =====================================================================

# --- Required ---
# PostgreSQL connection string. Get a free one from Neon (neon.tech) or
# Vercel Postgres in ~2 minutes — no install needed. Format:
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Use the SAME value locally (.env) and in your Vercel project settings.
DATABASE_URL="postgresql://user:password@host/renthive?sslmode=require"

# Signs session cookies. Generate one: `openssl rand -hex 32`
SESSION_SECRET="change-me-in-production"

# --- Optional: Online rent payments (Stripe) ---
# Set this + `npm i stripe` to take real payments via the tenant "Pay now" button.
# STRIPE_SECRET_KEY="sk_test_..."

# --- Optional: File uploads (AWS S3 or any S3-compatible store) ---
# Set these + `npm i @aws-sdk/client-s3` to store real document files.
# S3_BUCKET="renthive-files"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# S3_PUBLIC_URL=""   # optional CDN/base URL override

# --- Optional: Bank reconciliation (Plaid) ---
# Set these + `npm i plaid` to pull real bank statement lines.
# PLAID_CLIENT_ID="..."
# PLAID_SECRET="..."
# PLAID_ACCESS_TOKEN="..."
# PLAID_ENV="sandbox"   # sandbox | development | production

# --- Optional: Email notifications (Resend) ---
# Set this + `npm i resend` to send real emails.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="RentHive <you@yourdomain.com>"
